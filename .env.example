# Yūgen News Environment Variables
# Copy this file to .env and fill in your actual keys

# 1. NewsAPI (For fetching general topic news to be translated)
# Get a free key at https://newsapi.org/
VITE_NEWS_API_KEY=your_newsapi_key_here

# 2. Google Gemini (For rewriting articles into Japanese and injecting Kanji/Grammar)
# We will use this in the next step!
VITE_GEMINI_API_KEY=your_gemini_api_key_here
